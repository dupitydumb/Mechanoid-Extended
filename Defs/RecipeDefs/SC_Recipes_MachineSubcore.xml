<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>SC_Make_SubcoreRegular_Machined</defName>
    <label>assemble standard subcore (machined)</label>
    <description>Assemble a standard subcore at a machining table using advanced materials, bypassing the need for a human brain scan. This alternative method has a higher material cost but requires no human subjects.</description>
    <jobString>Assembling standard subcore.</jobString>
    <workAmount>12000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <recipeUsers>
      <li>TableMachining</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>250</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>6</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <SubcoreRegular>1</SubcoreRegular>
    </products>
    <skillRequirements>
      <Crafting>6</Crafting>
    </skillRequirements>
    <researchPrerequisite>SC_SpecialistMechs</researchPrerequisite>
  </RecipeDef>

  <RecipeDef>
    <defName>SC_Make_SubcoreHigh_Machined</defName>
    <label>assemble high subcore (machined)</label>
    <description>Assemble a high-tier subcore at a machining table using advanced materials, bypassing the need for a human brain rip-scan. This alternative method has a very high material cost but requires no human subjects.</description>
    <jobString>Assembling high subcore.</jobString>
    <workAmount>24000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <recipeUsers>
      <li>TableMachining</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>500</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>150</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Gold</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>SubcoreRegular</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Plasteel</li>
        <li>Gold</li>
        <li>ComponentSpacer</li>
        <li>SubcoreRegular</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <SubcoreHigh>1</SubcoreHigh>
    </products>
    <skillRequirements>
      <Crafting>8</Crafting>
    </skillRequirements>
    <researchPrerequisite>SC_AutonomousSystems</researchPrerequisite>
  </RecipeDef>

</Defs>
