<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Mining Drone -->
  <RecipeDef ParentName="LightMechanoidRecipe">
    <defName>SC_Gestate_MiningDrone</defName>
    <label>gestate mining drone</label>
    <description>Gestate a mining drone mechanoid.</description>
    <researchPrerequisite>SC_BasicMechExpansion</researchPrerequisite>
    <recipeUsers>
      <li>MechGestator</li>
    </recipeUsers>
    <ingredients Inherit="False">
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>75</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>SubcoreBasic</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <SC_Mech_MiningDrone>1</SC_Mech_MiningDrone>
    </products>
    <descriptionHyperlinks>
      <ThingDef>SC_Mech_MiningDrone</ThingDef>
    </descriptionHyperlinks>
  </RecipeDef>

