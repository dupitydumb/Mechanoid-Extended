<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>SC_MechControlRelay</defName>
    <label>mech control relay</label>
    <description>A high-power mechanoid control relay tower. It increases a mechanitor's bandwidth by 10 and, when powered, expands their effective control range. (Note: +10 bandwidth and range extension require Phase 3 C#; currently provides standard bandwidth).</description>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <canOverlapZones>false</canOverlapZones>
    <drawerType>MapMeshAndRealTime</drawerType>
    <fillPercent>0.5</fillPercent>
    <graphicData>
      <texPath>Things/Building/Misc/BandNode</texPath> <!-- Placeholder graphic -->
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,3)</drawSize>
      <shadowData>
        <volume>(1.8, 0.4, 1.4)</volume>
        <offset>(0, 0, -0.2)</offset>
      </shadowData>
      <color>(200, 160, 160)</color>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <buildingTags>
        <li>Biotech</li>
      </buildingTags>
    </building>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <designationCategory>Biotech</designationCategory>
    <uiOrder>2442</uiOrder>
    <statBases>
      <MaxHitPoints>350</MaxHitPoints>
      <WorkToBuild>18000</WorkToBuild>
      <Mass>50</Mass>
      <Flammability>0.5</Flammability>
    </statBases>
    <size>(2,2)</size>
    <costList>
      <Steel>200</Steel>
      <ComponentIndustrial>8</ComponentIndustrial>
      <Plasteel>25</Plasteel>
    </costList>
    <researchPrerequisites>
      <li>SC_SpecialistMechs</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>600</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_BandNode">
        <hediff>BandNode</hediff>
        <untunedEffect>BandNodeUntuned</untunedEffect>
        <tuningEffect>BandNodeTuning</tuningEffect>
        <tunedEffect>BandNodeTuned</tunedEffect>
        <retuningEffect>BandNodeRetuning</retuningEffect>
        <tuningCompleteSound>BandNodeTuning_Complete</tuningCompleteSound>
        <powerConsumptionIdle>150</powerConsumptionIdle>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_BandNode</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
  </ThingDef>

</Defs>
