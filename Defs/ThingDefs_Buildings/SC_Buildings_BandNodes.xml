<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>SC_AdvancedBandNode</defName>
    <label>advanced band node</label>
    <description>An advanced mechanoid-band signal amplifier. Advanced band nodes must be tuned to a specific mechanitor. This will add 5 bandwidth to that mechanitor's total bandwidth, allowing them to control more mechanoids.\n\nOnce constructed, it can be tuned to a mechanitor. (Note: +5 bandwidth requires Phase 3 C#; currently provides standard bandwidth).</description>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <canOverlapZones>false</canOverlapZones>
    <drawerType>MapMeshAndRealTime</drawerType>
    <fillPercent>0.4</fillPercent>
    <graphicData>
      <texPath>Things/Building/Misc/BandNode</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2,2)</drawSize>
      <shadowData>
        <volume>(1.5, 0.35, 1.2)</volume>
        <offset>(0, 0, -0.15)</offset>
      </shadowData>
      <color>(170, 190, 220)</color>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <buildingTags>
        <li>Biotech</li>
      </buildingTags>
    </building>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <designationCategory>Biotech</designationCategory>
    <uiOrder>2441</uiOrder>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>12000</WorkToBuild>
      <Mass>35</Mass>
      <Flammability>0.5</Flammability>
    </statBases>
    <size>(2,2)</size>
    <costList>
      <Steel>100</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
      <Plasteel>10</Plasteel>
    </costList>
    <researchPrerequisites>
      <li>SC_BasicMechExpansion</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>200</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_BandNode">
        <hediff>BandNode</hediff>
        <untunedEffect>BandNodeUntuned</untunedEffect>
        <tuningEffect>BandNodeTuning</tuningEffect>
        <tunedEffect>BandNodeTuned</tunedEffect>
        <retuningEffect>BandNodeRetuning</retuningEffect>
        <tuningCompleteSound>BandNodeTuning_Complete</tuningCompleteSound>
        <powerConsumptionIdle>100</powerConsumptionIdle>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_BandNode</li>
    </placeWorkers>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
  </ThingDef>

</Defs>
