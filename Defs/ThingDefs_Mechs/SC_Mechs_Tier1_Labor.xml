<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ==================== MINING DRONE ==================== -->
  <ThingDef ParentName="LightMechanoid">
    <defName>SC_Mech_MiningDrone</defName>
    <label>mining drone</label>
    <description>A light labor mechanoid designed for mining operations. It can mine ores and quarry stone, and haul materials.</description>
    <statBases>
      <MoveSpeed>3.0</MoveSpeed>
      <MiningSpeed>1.0</MiningSpeed>
      <MiningYield>1.0</MiningYield>
      <MechBandwidth>1</MechBandwidth>
      <MarketValue>800</MarketValue>
    </statBases>
    <race>
      <mechEnabledWorkTypes>
        <li>Mining</li>
        <li>Hauling</li>
      </mechEnabledWorkTypes>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Constructoid_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Constructoid_Death</soundDeath>
          <soundCall>Pawn_Mech_Constructoid_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="NonCombatLightMechanoidKind">
    <defName>SC_Mech_MiningDrone</defName>
    <label>mining drone</label>
    <race>SC_Mech_MiningDrone</race>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Constructoid</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Constructoid</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.1</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <!-- ==================== COOK UNIT ==================== -->
