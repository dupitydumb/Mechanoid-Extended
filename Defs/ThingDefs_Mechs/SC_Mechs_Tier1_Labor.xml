  <!-- ==================== HAULER MK2 ==================== -->
  <ThingDef ParentName="BaseMechanoidWalker">
    <defName>SC_Mech_HaulerMkII</defName>
    <label>hauler mk2</label>
    <description>A medium-sized work mechanoid designed for heavy-duty hauling. It has double the carrying capacity of a standard lifter and moves faster.</description>
    <statBases>
      <MoveSpeed>3.8</MoveSpeed>
      <CarryingCapacity>150</CarryingCapacity>
      <MechBandwidth>2</MechBandwidth>
      <MarketValue>1000</MarketValue>
    </statBases>
    <race>
      <body>Mech_Light</body>
      <baseBodySize>1.0</baseBodySize>
      <baseHealthScale>1.0</baseHealthScale>
      <mechWeightClass>Medium</mechWeightClass>
      <mechEnabledWorkTypes>
        <li>Hauling</li>
      </mechEnabledWorkTypes>
      <lifeStageAges Inherit="False">
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Lifter_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Lifter_Death</soundDeath>
          <soundCall>Pawn_Mech_Lifter_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="BaseMechanoidKind">
    <defName>SC_Mech_HaulerMkII</defName>
    <label>hauler mk2</label>
    <race>SC_Mech_HaulerMkII</race>
    <isFighter>false</isFighter>
    <combatPower>40</combatPower>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Lifter</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Liftman</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.3</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <!-- ==================== REFINERY REFUELER ==================== -->
  <ThingDef ParentName="LightMechanoid">
    <defName>SC_Mech_Refueler</defName>
    <label>refinery refueler</label>
    <description>A light labor mechanoid designed for raw material processing and fueling. It executes bulk bills like block cutting, smelting, and chemfuel refining, and maintains colony fuel levels.</description>
    <statBases>
      <MoveSpeed>3.0</MoveSpeed>
      <WorkSpeedGlobal>1.25</WorkSpeedGlobal> <!-- Fast bulk processing -->
      <MechBandwidth>1</MechBandwidth>
      <MarketValue>800</MarketValue>
    </statBases>
    <race>
      <mechEnabledWorkTypes>
        <li>Crafting</li>
        <li>Hauling</li>
      </mechEnabledWorkTypes>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Constructoid_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Constructoid_Death</soundDeath>
          <soundCall>Pawn_Mech_Constructoid_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="NonCombatLightMechanoidKind">
    <defName>SC_Mech_Refueler</defName>
    <label>refinery refueler</label>
    <race>SC_Mech_Refueler</race>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Fabricor</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Fabricor</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.15</drawSize>
          <color>(170, 160, 150)</color> <!-- Distinct clay/bronze tint -->
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

