<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ==================== ANIMAL HANDLER ==================== -->
  <ThingDef ParentName="BaseMechanoidWalker">
    <defName>SC_Mech_AnimalHandler</defName>
    <label>animal handler</label>
    <description>A medium-sized mechanoid designed for animal handling and hauling, equipped with pacifying pheromone emitters and audio modulators.</description>
    <statBases>
      <MoveSpeed>3.6</MoveSpeed>
      <MechBandwidth>2</MechBandwidth>
      <MarketValue>1200</MarketValue>
    </statBases>
    <race>
      <body>Mech_Light</body>
      <baseBodySize>1.0</baseBodySize>
      <baseHealthScale>1.2</baseHealthScale>
      <mechWeightClass>Medium</mechWeightClass>
      <mechEnabledWorkTypes>
        <li>Handling</li>
        <li>Hauling</li>
      </mechEnabledWorkTypes>
      <lifeStageAges Inherit="False">
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Agrihand_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Agrihand_Death</soundDeath>
          <soundCall>Pawn_Mech_Agrihand_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="BaseMechanoidKind">
    <defName>SC_Mech_AnimalHandler</defName>
    <label>animal handler</label>
    <race>SC_Mech_AnimalHandler</race>
    <isFighter>false</isFighter>
    <combatPower>60</combatPower>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Agrihand</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Agrihand</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.4</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>
