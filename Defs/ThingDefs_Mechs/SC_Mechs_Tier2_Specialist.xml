<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ==================== MEDIC UNIT ==================== -->
  <ThingDef ParentName="BaseMechanoidWalker">
    <defName>SC_Mech_MedicUnit</defName>
    <label>medic unit</label>
    <description>A medium-sized mechanoid designed for medical care and hauling. It features advanced diagnostic subroutines, granting superior medical tend quality and tend speed.</description>
    <statBases>
      <MoveSpeed>3.8</MoveSpeed>
      <MedicalTendQuality>0.80</MedicalTendQuality>
      <MedicalTendSpeed>1.20</MedicalTendSpeed>
      <MechBandwidth>2</MechBandwidth>
      <MarketValue>1200</MarketValue>
    </statBases>
    <race>
      <body>Mech_Light</body>
      <baseBodySize>1.0</baseBodySize>
      <baseHealthScale>1.2</baseHealthScale>
      <mechWeightClass>Medium</mechWeightClass>
      <mechEnabledWorkTypes>
        <li>Doctor</li>
        <li>Hauling</li>
      </mechEnabledWorkTypes>
      <lifeStageAges Inherit="False">
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Paramedic_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Paramedic_Death</soundDeath>
          <soundCall>Pawn_Mech_Paramedic_Call</soundCall>
        </li>
      </lifeStageAges>
    </race>
  </ThingDef>

  <PawnKindDef ParentName="BaseMechanoidKind">
    <defName>SC_Mech_MedicUnit</defName>
    <label>medic unit</label>
    <race>SC_Mech_MedicUnit</race>
    <isFighter>false</isFighter>
    <combatPower>60</combatPower>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Paramedic</texPath>
          <maskPath>Things/Pawn/Mechanoid/AllegianceOverlays/Mech_Paramedic</maskPath>
          <shaderType>CutoutWithOverlay</shaderType>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>1.4</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

